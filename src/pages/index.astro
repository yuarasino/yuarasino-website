---
import HomeLayout from "~/layouts/HomeLayout.astro";
import SvgIcon from "~/components/SvgIcon.astro";
import { cn } from "~/utils/tailwind";

const title = "HOME";
const description = "新篠ゆうのスタジオルーム";
---

<HomeLayout
  {title}
  {description}
>
  <main>
    <section>
      <h1 class={cn("text-pink-500")}>{title}</h1>
      <p class={cn("text-slate-500")}>
        <SvgIcon
          prefix="material-symbols-light"
          name="keyboard-double-arrow-down"
          label="コンテンツに進む"
        />
      </p>
    </section>
  </main>
</HomeLayout>
