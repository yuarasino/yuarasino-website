---
import { getCollection } from "astro:content"

import WorksItem from "@/components/WorksItem.astro"
import PageLayout from "@/layouts/PageLayout.astro"

const works = await getCollection("works")
---

<PageLayout title="Works | YuArasino WebSite">
  <main id="top" class="my-16 h-[200vw] px-8">
    <h1 class="font-ui text-6xl text-primary-500">Works</h1>
    <p class="text-xl">制作実績</p>
    <section class="my-16 @container">
      <div class="grid grid-cols-1 gap-8 @2xl:grid-cols-2">
        {works.map((work) => <WorksItem work={work} />)}
      </div>
    </section>
  </main>
</PageLayout>
