---
import { cn } from "~/utils/tailwind";

type Props = {
  class?: string;
  prefix: string;
  name: string;
  label: string;
};

const { class: class_, prefix, name, label } = Astro.props;
---

<span
  class={cn(
    "iconify",
    `${prefix}--${name}`,
    "inline-block",
    "size-6",
    class_,
  )}
  role="img"
  aria-label={label}
/>
